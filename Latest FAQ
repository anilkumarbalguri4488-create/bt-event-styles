/* 1. RESET THE ENTIRE TAB CONTENT AREA */
.conference360-event-faq-container, 
#faq-tab-content,
.conference360-event-tab-content-container,
.bt-faq-category-container {
    display: flex !important;
    flex-direction: column !important; /* Forces vertical list */
    position: relative !important;
    height: auto !important;
    min-height: 800px !important; /* Prevents the container from collapsing */
    overflow: visible !important;
    transform: none !important;
}

/* 2. KILL THE "DECK OF CARDS" STACKING */
.conference360-event-faq-item, 
div.faq-item,
[class*='faq-item'] {
    position: relative !important; /* THE CORE FIX: stops the overlapping */
    top: 0 !important;             /* Kills the JS 'top' pixel injection */
    left: 0 !important;
    display: block !important;
    width: 100% !important;
    margin-bottom: 25px !important; /* Forces space between boxes */
    background: #ffffff !important;
    border: 1px solid #d1d1d1 !important;
    border-radius: 8px !important;
    padding: 0 !important;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;
    transform: none !important;
    opacity: 1 !important;
    visibility: visible !important;
}

/* 3. STYLE THE QUESTION HEADERS */
.item-question, 
[class*='item-question'] {
    color: #18453B !important; /* MSU Green */
    font-weight: 800 !important;
    padding: 15px 15px 15px 40px !important;
}

/* 4. EXPANDED ANSWER BOX */
.faq-item-content,
[class*='faq-item-content'] {
    padding: 20px !important;
    background-color: #f9f9f9 !important;
    border-top: 1px solid #eeeeee !important;
}
