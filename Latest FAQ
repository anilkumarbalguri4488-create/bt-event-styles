/* 1. FORCE THE MAIN CONTAINER TO EXPAND VERTICALLY */
.conference360-event-faq-container, 
#faq-tab-content,
[class*="faq-content"],
[class*="faq-items"] {
    display: flex !important;
    flex-direction: column !important; /* This forces a vertical list */
    position: relative !important;
    height: auto !important;
    min-height: 1200px !important;
    overflow: visible !important;
    transform: none !important;
}

/* 2. KILL THE STACKED CARD POSITIONING (THE CORE FIX) */
div.faq-item,
.conference360-event-faq-item,
[class*="faq-item"] {
    position: relative !important; /* Stops the boxes from overlapping */
    top: 0 !important;             /* Kills the script-calculated top pixels */
    left: 0 !important;            /* Kills the script-calculated left pixels */
    display: block !important;
    width: 100% !important;
    margin-bottom: 25px !important; /* Forces real space between boxes */
    background: #ffffff !important;
    border: 1px solid #d1d1d1 !important;
    border-radius: 8px !important;
    transform: none !important;     /* Stops the sliding animation */
    opacity: 1 !important;
    visibility: visible !important;
}

/* 3. STYLE THE QUESTION HEADERS */
.item-question, 
[class*="item-question"] {
    color: #18453B !important; /* MSU Green */
    font-weight: 800 !important;
    padding-left: 35px !important;
}

/* 4. EXPANDED ANSWER AREA */
.faq-item-content,
[class*="faq-item-content"] {
    padding: 20px !important;
    background-color: #f9f9f9 !important;
    border-top: 1px solid #eeeeee !important;
}
