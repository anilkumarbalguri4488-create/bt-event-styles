/* 1. RESET THE ENTIRE TAB CONTENT AREA */
#faq-tab-content,
.conference360-event-faq-container, 
.faq-content[_ngcontent-ng-c3568271570], 
.faq-items[_ngcontent-ng-c3568271570] {
    display: block !important;
    position: relative !important;
    height: auto !important;
    min-height: 500px !important; /* Forces the container to expand */
    overflow: visible !important;
    transform: none !important;
}

/* 2. FORCE EACH FAQ TO BE A STANDALONE BOX (UNSTACKED) */
.conference360-event-faq-item,
div.faq-item[_ngcontent-ng-c3568271570] {
    position: relative !important; /* This kills the 'absolute' stacking */
    display: block !important;
    top: auto !important; 
    left: auto !important;
    width: 100% !important;
    margin-bottom: 25px !important;
    background: #ffffff !important;
    border: 1px solid #d1d1d1 !important;
    border-radius: 8px !important;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;
    transform: none !important;
    opacity: 1 !important;
    visibility: visible !important;
}

/* 3. STYLE THE QUESTION HEADERS */
.item-question[_ngcontent-ng-c3568271570] {
    color: #18453B !important; /* MSU Green */
    font-weight: 800 !important;
    font-size: 1.1rem !important;
}

/* 4. STYLE THE ANSWER AREA */
.faq-item-content[_ngcontent-ng-c3568271570] {
    padding: 20px !important;
    border-top: 1px solid #f0f0f0 !important;
    background-color: #fafafa !important;
}
